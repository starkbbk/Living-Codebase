# 1. Configuration for Kernel eBPF files only
If:
  PathMatch: ebpf/.*\.c
CompileFlags:
  Add: [
    "-Iebpf/mock_headers",
    "-target", "bpf"
  ]

---

# 2. Configuration for Userspace C files (macOS SDK inclusion)
If:
  PathMatch: hotswap/.*\.c
CompileFlags:
  Add: [
    "-isysroot", "/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk"
  ]
